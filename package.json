{
  "name": "auto-generate-code-from-linear",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "start": "vp exec tsx --env-file=.env src/main.ts",
    "dev:server": "vp exec tsx --env-file=.env src/main.dev.ts",
    "dev:local": "vp exec tsx --env-file=.env src/main.local.ts",
    "preview": "vp preview",
    "prepare": "husky",
    "test": "vp test run",
    "lint": "vp check --fix && vp lint && vp build &&pnpm run lint:duplicates",
    "lint:duplicates": "jscpd ./src",
    "eval": "promptfoo eval",
    "deploy": "fly deploy",
    "deploy:logs": "fly logs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@chat-adapter/slack": "^4.23.0",
    "@chat-adapter/state-memory": "^4.23.0",
    "@chat-adapter/state-pg": "^4.23.0",
    "@linear/sdk": "^78.0.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "ai": "^6.0.141",
    "chat": "^4.23.0",
    "express": "^5.2.1",
    "nunjucks": "^3.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6",
    "archgate": "^0.26.1",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "localtunnel": "^2.0.2",
    "oxlint": "^1.56.0",
    "promptfoo": "^0.121.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-oxlint": "^2.0.1",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.14"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
