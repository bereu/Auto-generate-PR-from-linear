{
  "name": "auto-generate-code-from-linear",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vp exec tsx src/index.ts",
    "preview": "vp preview",
    "prepare": "husky",
    "lint": "vp check --fix && vp lint && pnpm run lint:duplicates",
    "lint:duplicates": "jscpd ./src",
    "eval": "promptfoo eval",
    "deploy": "fly deploy",
    "deploy:logs": "fly logs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@linear/sdk": "^78.0.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "oxlint": "^1.56.0",
    "promptfoo": "^0.121.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-oxlint": "^2.0.1",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
